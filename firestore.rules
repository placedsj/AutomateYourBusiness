rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Checks if the document ID matches standard clean word characters to prevent poisoning/exhaustion.
    function isValidId(id) {
      return id.size() > 0 && id.size() <= 100 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default rule: Secure all records by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // System configuration rules.
    match /system/config {
      // Allow administration reading, restrict writing by default unless admin.
      allow read: if true;
      allow write: if false;
    }

    // Invoices rules.
    match /invoices/{invoiceId} {
      allow read, write: if isValidId(invoiceId);
    }

    // Checkins rules.
    match /checkins/{checkInId} {
      allow read, write: if isValidId(checkInId);
    }

    // Logs rules.
    match /logs/{logId} {
      allow read, write: if isValidId(logId);
    }

    // Emails rules.
    match /emails/{emailId} {
      allow read, write: if isValidId(emailId);
    }
  }
}
